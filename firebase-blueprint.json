{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system (Student, Supervisor, or Admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "field_supervisor", "academic_supervisor", "admin"] },
        "accessNumber": { "type": "string", "description": "Student access number (e.g., AR6159)" },
        "phoneNumber": { "type": "string" },
        "academicSupervisor": { "type": "string" },
        "internshipDuration": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "learnedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "Log": {
      "title": "Log",
      "description": "A daily internship log entry.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "activity": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "supervisor": { "type": "string" },
        "feedback": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "date", "activity", "status"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] }
      },
      "required": ["studentId", "date", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System-wide or targeted notification.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "target": { "type": "string", "enum": ["all", "student", "field_supervisor", "academic_supervisor"] },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "target", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "Internship log entries."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System notifications."
    }
  }
}
